# =============================================================
# OpsPulse AI — Environment Variables Template
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# On Vercel: set these in Project Settings → Environment Variables.

# =============================================================
# SUPABASE CONFIGURATION
# =============================================================
# Get these from: https://app.supabase.com → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key — server-side ONLY (seed scripts, admin ops)
# NEVER expose this in client-side code or NEXT_PUBLIC_ vars
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# =============================================================
# APP CONFIGURATION
# =============================================================
NEXT_PUBLIC_APP_NAME=OpsPulse AI
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Data refresh interval in milliseconds (default: 15000 = 15 seconds)
NEXT_PUBLIC_REFRESH_INTERVAL=15000

# =============================================================
# FEATURE FLAGS
# =============================================================
# Set to "true" to use mock/synthetic data instead of Supabase.
# Use this for demo deployments or when Supabase is not connected.
NEXT_PUBLIC_USE_MOCK_DATA=true

# =============================================================
# SECURITY — API AUTHENTICATION
# =============================================================
# Set a strong random secret to protect all /api/* routes.
# When set, every API request must include one of:
#   Authorization: Bearer <API_SECRET_KEY>
#   X-API-Key: <API_SECRET_KEY>
#
# Generate a secure key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   openssl rand -hex 32
#
# Leave EMPTY to disable API key auth (dev/demo mode only).
# ALWAYS set this in production.
API_SECRET_KEY=

# =============================================================
# SECURITY — CORS
# =============================================================
# Comma-separated list of allowed origins for cross-origin requests.
# Example: https://app.yourcompany.com,https://admin.yourcompany.com
#
# Leave EMPTY to auto-allow localhost (dev) and NEXT_PUBLIC_APP_URL (prod).
ALLOWED_ORIGINS=

# =============================================================
# SECURITY — RATE LIMITING (Upstash Redis — optional upgrade)
# =============================================================
# For persistent rate limiting across Vercel serverless instances,
# connect Upstash Redis. Without this, rate limiting is per-instance
# (still effective, but not globally coordinated).
#
# Get these from: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================
# SECURITY — SESSION / AUTH (future Supabase Auth integration)
# =============================================================
# NEXTAUTH_SECRET=your-nextauth-secret-here
# NEXTAUTH_URL=https://your-app.vercel.app

# =============================================================
# MONITORING & OBSERVABILITY (optional)
# =============================================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log level: debug | info | warn | error
# LOG_LEVEL=info
